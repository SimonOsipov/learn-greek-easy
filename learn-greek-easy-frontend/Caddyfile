# Static assets with long-term caching
@static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
handle @static {
	header Cache-Control "public, max-age=31536000, immutable"
	file_server
}

# Reject source map requests (no prod sourcemaps; prevent accidental 200).
# NOTE: a bare top-level `respond @matcher` is evaluated AFTER handle blocks
# in Caddy's directive order (verified via caddy:alpine — it does NOT beat the
# SPA catch-all handle{} below), so a bare `respond @sourcemaps 404` here was
# actually dead code (*.map requests fell through to the SPA fallback, a real
# info-leak). Wrapped in `handle` to join the same specificity-sorted group
# as the other handle blocks above, same fix as @dotfileProbes below.
@sourcemaps path *.map
handle @sourcemaps {
	respond 404
}

# Reject dotfile / VCS probes site-wide (e.g. /.git, /.git/config, /some/.env).
# Wrapped in `handle` for the same reason as @sourcemaps above.
# /api/v1/.env and /api/v1/.git(/*) are covered separately by the nested
# `route {}` inside handle /api/v1/* above (respond-before-proxy, in written
# order) — this site-wide matcher and that one together fully close AC 5.
@dotfileProbes path */.env */.git */.git/*
handle @dotfileProbes {
	respond 404
}

# SPA fallback - serve index.html for all other routes
handle {
	header /index.html Cache-Control "no-cache, must-revalidate"
	try_files {path} /index.html
	file_server
}

# Security headers (applied globally)
header {
	X-Frame-Options "SAMEORIGIN"
	X-Content-Type-Options "nosniff"
	X-XSS-Protection "1; mode=block"
	Referrer-Policy "no-referrer-when-downgrade"
	# Required for Sentry browser profiling
	Document-Policy "js-profiling"
}
