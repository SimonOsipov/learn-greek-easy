:{$PORT:80}

root * /srv
encode zstd gzip

# Logging for debugging
log {
	output stdout
	format json
	level INFO
}

# Frontend deploy-gate healthcheck — Caddy-local static 200, NEVER proxied.
# Railway's Frontend healthcheck path points here (OPS-03-04 runbook) so the
# frontend's deploy gate stays decoupled from backend health: a backend outage
# must not fail the frontend's deploy. handle blocks sort by matcher
# specificity, so the literal /healthz wins over the /health* glob below (same
# mechanism /api/v1/* uses to beat /api/*) and never reaches reverse_proxy.
handle /healthz {
	respond 200
}

# Health check endpoints - proxy to backend for real health data
# Matches /health, /health/live, /health/ready
handle /health* {
	reverse_proxy {
		dynamic a {$BACKEND_HOST:backend.railway.internal} {$BACKEND_PORT:8080} {
			refresh 1s
			versions ipv4 ipv6
			resolvers fd12::10
			dial_timeout 30s
		}

		# Aggressive load balancer retries (Railway recommended)
		lb_try_duration 10s
		lb_try_interval 250ms
		lb_retries 100

		# Relaxed passive health checks (Railway recommended)
		# Prevents marking backend unhealthy too fast during DNS transitions
		fail_duration 60s
		max_fails 300
		unhealthy_status 502 503 504
		unhealthy_request_count 200

		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Version endpoint - proxy to backend
handle /version {
	reverse_proxy {
		dynamic a {$BACKEND_HOST:backend.railway.internal} {$BACKEND_PORT:8080} {
			refresh 1s
			versions ipv4 ipv6
			resolvers fd12::10
			dial_timeout 30s
		}

		lb_try_duration 10s
		lb_try_interval 250ms
		lb_retries 100

		fail_duration 60s
		max_fails 300
		unhealthy_status 502 503 504
		unhealthy_request_count 200

		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Real API namespace — proxy /api/v1/* to backend with dynamic DNS resolution for Railway
# Uses dynamic A record lookup with 1s refresh to handle backend IP changes
# Includes Railway's internal DNS resolver to bypass system DNS caching
# NOTE: a top-level `route /api/v1/*` (instead of `handle /api/v1/*`) was tried
# and rejected — it pulls this block OUT of the handle-block specificity-sorted
# group, so it loses to the less-specific `handle /api/* { respond 404 }` below
# and ALL /api/v1/* traffic (incl. the Stripe webhook) 404s at the edge instead
# of proxying. Verified live. Keeping `handle /api/v1/*` as the outer matcher
# preserves correct specificity-group ordering; the nested `route {}` below
# forces its two directives to run in WRITTEN order (dotfile check before
# reverse_proxy) instead of Caddy's normal directiveOrder-based reordering.
handle /api/v1/* {
	route {
		# Reject dotfile / VCS probes inside the v1 namespace (e.g. /api/v1/.env,
		# /api/v1/.git, /api/v1/.git/config) before they reach the backend.
		@v1dotfiles path */.env */.git */.git/*
		respond @v1dotfiles 404

		reverse_proxy {
			dynamic a {$BACKEND_HOST:backend.railway.internal} {$BACKEND_PORT:8080} {
				refresh 1s
				versions ipv4 ipv6
				resolvers fd12::10
				dial_timeout 30s
			}

			# Buffer request body to prevent streaming race condition
			# Ensures entire POST body is read before selecting upstream
			request_buffers 1MB

			# Allow retries for mutating methods (default is GET only)
			lb_retry_match {
				method POST PUT PATCH DELETE
			}

			# Aggressive load balancer retries (Railway recommended)
			# User never sees 502 from stale IPs - Caddy retries with fresh DNS
			lb_try_duration 10s
			lb_try_interval 250ms
			lb_retries 100

			# Relaxed passive health checks (Railway recommended)
			# Prevents marking backend unhealthy too fast during DNS transitions
			fail_duration 60s
			max_fails 300
			unhealthy_status 502 503 504
			unhealthy_latency 5s
			unhealthy_request_count 200

			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}

			transport http {
				read_timeout 120s
				write_timeout 120s
				keepalive 30s
				keepalive_idle_conns 10
			}
		}
	}
}

# Everything else under /api/ is scanner noise (non-v1 leak-path probes) —
# answer a flat 404 at the edge so it never reaches the backend / Redis / Sentry.
# handle blocks sort by matcher specificity, so /api/v1/* above always wins.
handle /api/* {
	respond 404
}

