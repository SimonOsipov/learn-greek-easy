{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "src/**/__tests__/**/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test-utils/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "src/i18n/__tests__/missingKeyHandler.test.ts"
  ]
}
