{
  // Solution file — `tsc -b` from this directory walks all referenced projects.
  // - tsconfig.app.json: production sources under src/ (no test files)
  // - tsconfig.test.json: vitest/playwright tests — standalone config, checked via
  //   `npm run typecheck:test` (tsc -p tsconfig.test.json --noEmit). Not listed here
  //   as a reference because it extends tsconfig.app.json directly (composite:false).
  // - tsconfig.node.json: vite/vitest/playwright config files
  // The `typecheck:ci` npm script invokes `tsc -b` so it covers the SAME files as `npm run build`.
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "files": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }]
}
