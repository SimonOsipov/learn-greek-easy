# ============================================================
# Learn Greek Easy — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/greekly

# ============================================================
# Auth (Supabase JWKS / JWT)
# ============================================================
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<anon-key>
JWT_SECRET_KEY=<min-32-char-secret>

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:5173

# ============================================================
# OpenRouter API (LLM Gateway)
# ============================================================
OPENROUTER_API_KEY=<your-openrouter-api-key>
# Optional — defaults shown
# OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================
# Picture Generation (SIT-08, SCENE-01)
# ============================================================
# House style fragment appended to every news picture prompt. Required — no default.
PICTURE_HOUSE_STYLE_DEFAULT=<your-house-style-prompt-fragment>

# Model used for situation picture generation (SIT-08). Default: google/gemini-3.1-flash-image-preview
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Aspect ratio for generated situation pictures. Default: 16:9
OPENROUTER_IMAGE_ASPECT_RATIO=16:9
